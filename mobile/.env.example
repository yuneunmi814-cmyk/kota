# API 베이스 (안드로이드 에뮬레이터 기본 10.0.2.2). 실기기는 PC의 LAN IP로.
EXPO_PUBLIC_API_BASE=http://10.0.2.2:4000/api/v1

# 카카오 네이티브 앱 키 — 카카오 개발자센터 발급. 설정 시 카카오 로그인 + 네이티브 지도(내장 POI, dev build 필요) 활성.
# 비우면 카카오 로그인 버튼 비활성.
EXPO_PUBLIC_KAKAO_NATIVE_KEY=

# 카카오 JavaScript 키 — 설정 시 지도를 WebView+JS SDK로 렌더(번호 마커·경로선, Expo Go에서도 동작).
# 카카오 콘솔 > 플랫폼 > Web 에 아래 도메인을 등록해야 함.
EXPO_PUBLIC_KAKAO_JS_KEY=
EXPO_PUBLIC_KAKAO_MAP_DOMAIN=https://travelpack.app

# 구글 로그인 — Google Cloud OAuth 클라이언트 ID. 웹 클라이언트 ID는 백엔드 GOOGLE_CLIENT_ID(aud 검증)와 동일해야 함.
# 비우면 구글 로그인 버튼 비활성.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# 사업자 신원정보 (전자상거래법 §10) — 앱 "사업자 정보·약관" 화면에 표시. 개인정보라 .env(gitignore)에만 설정.
EXPO_PUBLIC_BIZ_NAME=프로젝트윤
EXPO_PUBLIC_BIZ_CEO=
EXPO_PUBLIC_BIZ_REG_NO=
EXPO_PUBLIC_BIZ_ADDRESS=
EXPO_PUBLIC_BIZ_TEL=
EXPO_PUBLIC_BIZ_EMAIL=
EXPO_PUBLIC_BIZ_MAILORDER_NO=
EXPO_PUBLIC_BIZ_LBS_NO=
# 약관 전문 호스팅 베이스 URL (예: https://travelpack.app/legal). 비우면 앱에서 "준비 중" 안내.
EXPO_PUBLIC_LEGAL_BASE_URL=
